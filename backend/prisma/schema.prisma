// backend/prisma/schema.prisma

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int    @id @default(autoincrement())
  userId   String @unique // This matches your Firebase UID
  passcode String
  theme    String @default("default")
}

// 🟢 NEW: The Archive Vault Table
model Session {
  id           Int      @id @default(autoincrement())
  userId       String   
  summary      String   
  suggestions  String   // JSON string of the shopping list
  imageUrl     String?  // URL of the GetImg generated design
  style        String   
  goal         String   
  date         String   
  createdAt    DateTime @default(now())
}